{
  "manifest_version": 3,
  "name": "DeepSeek Sidebar",
  "version": "1.0",
  "description": "Open DeepSeek mobile in Chrome sidebar with zoom support",
  "permissions": ["sidePanel", "activeTab", "storage", "declarativeNetRequest"],
  "host_permissions": ["https://chat.deepseek.com/*"],
  "action": {
    "default_title": "Open DeepSeek Sidebar",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "declarative_net_request": {
    "rule_resources": [{
      "id": "remove_headers",
      "enabled": true,
      "path": "rules.json"
    }]
  }
}
