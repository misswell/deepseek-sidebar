{
  "manifest_version": 3,
  "name": "AI Sidebar",
  "version": "1.1",
  "description": "Open AI chat mobile sites in Chrome sidebar with quick switch and zoom support",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "declarativeNetRequest", "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://www.qianwen.com/*",
    "https://m.qianwen.com/*",
    "https://qianwen.com/*"
  ],
  "action": {
    "default_title": "Open AI Sidebar",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "remove_headers",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}