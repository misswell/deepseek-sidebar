{
  "manifest_version": 3,
  "name": "DeepSeek Sidebar",
  "version": "1.3",
  "description": "Open AI chat mobile sites in Chrome sidebar with quick switch and zoom support",
  "permissions": [
    "sidePanel",
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://chat.z.ai/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://www.kimi.com/*",
    "https://kimi.com/*",
    "https://www.qianwen.com/*",
    "https://qianwen.com/*"
  ],
  "action": {
    "default_title": "Open AI Sidebar",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "remove_headers",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.qianwen.com/*",
        "https://qianwen.com/*"
      ],
      "js": [
        "ua-override.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ]
}
